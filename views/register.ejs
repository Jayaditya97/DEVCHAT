<!DOCTYPE html>
<html>
<head>
  <title>Register</title>
</head>
<body>

<h1>Register</h1>

<form id="registerForm">

<input
  type="text"
  id="name"
  placeholder="Name"
/>

<br><br>

<input
  type="email"
  id="email"
  placeholder="Email"
/>

<br><br>

<input
  type="password"
  id="password"
  placeholder="Password"
/>

<br><br>

<button type="submit">
Register
</button>

</form>

<script>

document
.getElementById("registerForm")
.addEventListener("submit", async (e) => {

  e.preventDefault();

  const response = await fetch(
    "/api/auth/register",
    {
      method: "POST",

      headers: {
        "Content-Type":
          "application/json",
      },

      body: JSON.stringify({
        name:
          document.getElementById(
            "name"
          ).value,

        email:
          document.getElementById(
            "email"
          ).value,

        password:
          document.getElementById(
            "password"
          ).value,
      }),
    }
  );

  const data = await response.json();

  localStorage.setItem(
    "token",
    data.token
  );

window.location.href =
  "/chat.html";

});

</script>

</body>
</html>